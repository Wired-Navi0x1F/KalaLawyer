# The Kala Lawyers - Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.

# Legacy Flask configuration (if applicable)
FLASK_SECRET_KEY=your_flask_secret_key_here
ADMIN_USERNAME=admin_username_here
ADMIN_PASSWORD=admin_password_here

# Supabase database & serverless credentials
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_private_key_here
